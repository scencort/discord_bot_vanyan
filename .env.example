BOT_TOKEN=your_bot_token_here
VOICE_CHANNEL_ID=123456789012345678
# Optional: list user IDs separated by comma; these users can use moderation commands even without admin role.
OWNER_USER_ID=123456789012345678
DB_PATH=bot_data.sqlite3
# 1 = full mode (requires privileged intents in Discord Portal), 0 = limited mode
USE_PRIVILEGED_INTENTS=1
